# Database (required for auth and registration)
# PostgreSQL example (e.g. Neon, Vercel Postgres, Supabase, or local):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth (required)
NEXTAUTH_SECRET="generate-a-long-random-string-for-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: OAuth providers (if using Google/GitHub login)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Optional: public site URL for API base
# NEXT_PUBLIC_SITE_URL=
